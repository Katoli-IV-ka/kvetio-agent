# Kvetio Agent — пример .env
# Скопировать в .env и заполнить реальными значениями
# .env добавлен в .gitignore — никогда не коммитить!

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Telegram ──────────────────────────────────────────────────────────────────
# Создать бота: @BotFather → /newbot → получить TOKEN
# Узнать chat_id: написать боту и вызвать
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=123456789

# ── Telegram Management Bot (bot/) ────────────────────────────────────────────
# Секрет для проверки подлинности webhook-запросов от Telegram
TELEGRAM_WEBHOOK_SECRET=generate-a-random-string-here
# Публичный URL вебхука (Railway: https://<app>.up.railway.app/telegram/webhook)
BOT_WEBHOOK_URL=https://<app>.up.railway.app/telegram/webhook

# ── Claude Code Routine (триггер pipeline) ────────────────────────────────────
# URL /fire эндпоинта рутины (claude.ai/code → Settings → Routines)
ROUTINE_FIRE_URL=https://api.anthropic.com/v1/...
# Bearer-токен для авторизации вызова рутины
ROUTINE_TOKEN=generate-a-random-string-here

# ── Notion (прямой API-доступ для scripts/notion_sync.py) ────────────────────
# Токен интеграции: https://www.notion.so/my-integrations (тип Internal)
# Интеграцию нужно расшарить на обе базы (Companies, Contacts).
NOTION_TOKEN=secret_xxx
NOTION_COMPANIES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CONTACTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxx

# ── HuggingFace ───────────────────────────────────────────────────────────────
# HuggingFace (опциональный — расширяет лимиты до ~1000 req/min)
HF_TOKEN=

# ── Опционально (после MVP) ───────────────────────────────────────────────────
# APOLLO_API_KEY=

# ── Логирование ───────────────────────────────────────────────────────────────
KVETIO_LOG_LEVEL=INFO
