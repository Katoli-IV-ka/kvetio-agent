# Kvetio Agent — пример .env
# Скопировать в .env и заполнить реальными значениями
# .env добавлен в .gitignore — никогда не коммитить!

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Telegram ──────────────────────────────────────────────────────────────────
# Создать бота: @BotFather → /newbot → получить TOKEN
# Узнать chat_id: написать боту и вызвать
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=123456789

# ── Notion (MCP использует отдельный конфиг плагина) ─────────────────────────
# Notion MCP управляется через Cowork — токен здесь не нужен
# NOTION_DATABASE_ID нужен только если вызываешь Notion напрямую из скриптов
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxx

# ── HuggingFace ───────────────────────────────────────────────────────────────
# HuggingFace (опциональный — расширяет лимиты до ~1000 req/min)
HF_TOKEN=

# ── Опционально (после MVP) ───────────────────────────────────────────────────
# APOLLO_API_KEY=

# ── Логирование ───────────────────────────────────────────────────────────────
KVETIO_LOG_LEVEL=INFO
